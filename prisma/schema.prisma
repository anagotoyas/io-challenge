// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model CardRequest {
  requestId      String   @id @default(uuid()) @map("request_id")
  documentType   String   @map("document_type")
  documentNumber String   @unique @map("document_number")
  fullName       String   @map("full_name")
  age            Int
  email          String
  cardType       String   @map("card_type")
  currency       String
  status         String   @default("pending")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  issuedCard IssuedCard?

  @@map("card_requests")
}

model ProcessedEvent {
  eventId     String   @id @map("event_id")
  processedAt DateTime @default(now()) @map("processed_at")

  @@map("processed_events")
}

model IssuedCard {
  cardId     String   @id @default(uuid()) @map("card_id")
  requestId  String   @unique @map("request_id")
  cardNumber String   @map("card_number")
  expiresAt  String   @map("expires_at")
  cvv        String
  issuedAt   DateTime @default(now()) @map("issued_at")

  cardRequest CardRequest @relation(fields: [requestId], references: [requestId])

  @@map("issued_cards")
}
